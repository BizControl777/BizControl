{
  "name": "bizcontrol",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "biz": "./gemini-cli.js"
  },
  "main": "electron/main.cjs",
  "description": "Sistema de gestão BizControl",
  "author": "Cleiton Ernesto Cumbane",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "node scripts/run-electron.cjs",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && npm run electron\"",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^11.10.0",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.2",
    "readline-sync": "^1.4.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^4.4.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bizcontrol.app",
    "productName": "BizControl",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis",
      "icon": "public/bizcontrol.png",
      "artifactName": "BizControl-Setup-${version}.${ext}"
    }
  },
  "keywords": [],
  "license": "ISC"
}
